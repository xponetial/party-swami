NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
OPENAI_MODEL_PLAN=gpt-5.4-mini
OPENAI_MODEL_LIGHTWEIGHT=gpt-5.4-nano
OPENAI_MODEL_PREMIUM=gpt-5.4
# Optional for Amazon affiliate attribution in shopping redirects.
# Set this in stage first (example: partyswami-20).
AMAZON_ASSOCIATE_TAG=
# Optional for stable Amazon product image resolution without PA-API.
# Supported provider: rainforest
AMAZON_IMAGE_PROVIDER=
RAINFOREST_API_KEY=
# Optional Amazon storefront domain passed to provider (default: amazon.com)
AMAZON_IMAGE_PROVIDER_AMAZON_DOMAIN=amazon.com
# Delay between Amazon category search batches during recommendation enrichment.
# Increase if Amazon starts returning 503s to server-side search requests.
AMAZON_SEARCH_CATEGORY_DELAY_MS=5000
# Optional delay between item searches inside the same category.
AMAZON_SEARCH_ITEM_DELAY_MS=0
RESEND_API_KEY=
RESEND_FROM_EMAIL="Party Swami <noreply@email.partyswami.com>"
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO_MONTHLY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Upstash Redis — required for distributed rate limiting in production (serverless-safe).
# Without these, rate limiting falls back to in-memory (unreliable across instances).
# Get credentials at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
