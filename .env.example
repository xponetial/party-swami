NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
OPENAI_MODEL_PLAN=gpt-5.4-mini
OPENAI_MODEL_LIGHTWEIGHT=gpt-5.4-nano
OPENAI_MODEL_PREMIUM=gpt-5.4
# Optional for Amazon affiliate attribution in shopping redirects.
# Set this in stage first (example: partyswami-20).
AMAZON_ASSOCIATE_TAG=
# Optional for curated product enrichment (real images/product URLs/prices)
# without Amazon PA-API credentials. By default the app reads:
# data/amazon-curated-catalog.json
# You can override with either:
# AMAZON_CURATED_CATALOG_PATH=relative/or/absolute/path/to/catalog.json
# AMAZON_CURATED_CATALOG_JSON=[{...}, {...}]
AMAZON_CURATED_CATALOG_PATH=
AMAZON_CURATED_CATALOG_JSON=
RESEND_API_KEY=
RESEND_FROM_EMAIL="Party Swami <noreply@email.partyswami.com>"
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO_MONTHLY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Upstash Redis — required for distributed rate limiting in production (serverless-safe).
# Without these, rate limiting falls back to in-memory (unreliable across instances).
# Get credentials at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
