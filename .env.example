NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
OPENAI_MODEL_PLAN=gpt-5.4-mini
OPENAI_MODEL_LIGHTWEIGHT=gpt-5.4-nano
OPENAI_MODEL_PREMIUM=gpt-5.4
# Optional for Amazon affiliate attribution in shopping redirects.
# Set this in stage first (example: partyswami-20).
AMAZON_ASSOCIATE_TAG=
# Optional for live Amazon product enrichment (real images/product URLs/prices).
# When these are set, shopping generation will enrich recommendations with
# real Amazon catalog metadata before saving to the event shopping list.
AMAZON_PAAPI_ACCESS_KEY=
AMAZON_PAAPI_SECRET_KEY=
# Optional override; defaults to AMAZON_ASSOCIATE_TAG when omitted.
AMAZON_PAAPI_PARTNER_TAG=
AMAZON_PAAPI_PARTNER_TYPE=Associates
AMAZON_PAAPI_HOST=webservices.amazon.com
AMAZON_PAAPI_REGION=us-east-1
AMAZON_PAAPI_MARKETPLACE=www.amazon.com
RESEND_API_KEY=
RESEND_FROM_EMAIL="Party Swami <noreply@email.partyswami.com>"
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO_MONTHLY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Upstash Redis — required for distributed rate limiting in production (serverless-safe).
# Without these, rate limiting falls back to in-memory (unreliable across instances).
# Get credentials at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
